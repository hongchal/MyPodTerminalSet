# ── History ──────────────────────────────────────────────
export HISTSIZE=100000
export HISTFILESIZE=200000
export HISTCONTROL=ignoreboth:erasedups
export HISTTIMEFORMAT="%F %T  "
shopt -s histappend checkwinsize globstar 2>/dev/null
PROMPT_COMMAND="history -a; history -n; ${PROMPT_COMMAND:-}"

# ── PATH ─────────────────────────────────────────────────
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# ── Locale (defensive: only export what the system actually has) ────
if locale -a 2>/dev/null | grep -qi '^en_US\.utf-\?8$'; then
  export LANG=en_US.UTF-8
  export LC_ALL=en_US.UTF-8
elif locale -a 2>/dev/null | grep -qi '^C\.utf-\?8$'; then
  export LANG=C.UTF-8
  export LC_ALL=C.UTF-8
fi

# ── Aliases ──────────────────────────────────────────────
alias ll='ls -lah --color=auto'
alias la='ls -A --color=auto'
alias l='ls -CF --color=auto'
alias grep='grep --color=auto'
alias ..='cd ..'
alias ...='cd ../..'

alias gs='git status -sb'
alias gd='git diff'
alias gds='git diff --staged'
alias ga='git add'
alias gl='git log --oneline --graph --decorate --all -30'
alias gb='git branch -vv'
alias gco='git checkout'
alias lg='lazygit'

alias tn='tmux new -A -s'
alias ta='tmux attach -t'
alias tl='tmux ls'

# ── GitHub 계정 분리 ─────────────────────────────────────
# Pod 환경에선 GITHUB_TOKEN env가 잡혀 있지 않은 게 정상이지만,
# 혹시 어디서 export 되더라도 충돌 방지 헬퍼 둠.
gh-push-hongchal() {
  ( unset GITHUB_TOKEN GH_TOKEN GITHUB_USERNAME
    gh auth switch -u hongchal >/dev/null 2>&1 || true
    git push "$@" )
}
gh-push-thakicloud() {
  ( unset GITHUB_TOKEN GH_TOKEN GITHUB_USERNAME
    gh auth switch -u chohongcheol-thakicloud >/dev/null 2>&1 || true
    git push "$@" )
}

# ── secrets-status ──────────────────────────────────────
# 부트스트랩 repo 경로 가정 (없으면 alias 무시)
if [ -f /DATA1/hongcheol/dotfiles/scripts/secrets-status.sh ]; then
  alias secrets-status='bash /DATA1/hongcheol/dotfiles/scripts/secrets-status.sh'
fi

# ── direnv ──────────────────────────────────────────────
command -v direnv >/dev/null && eval "$(direnv hook bash)"

# ── git-aware prompt ────────────────────────────────────
# Disable on slow / huge mounts: export MTS_NO_GIT_PROMPT=1
if [ -z "${MTS_NO_GIT_PROMPT:-}" ] && [ -f "$HOME/.git-prompt.sh" ]; then
  source "$HOME/.git-prompt.sh"
  export GIT_PS1_SHOWDIRTYSTATE=1
  export GIT_PS1_SHOWUNTRACKEDFILES=
  export GIT_PS1_SHOWUPSTREAM="auto"
  PS1='\[\e[32m\]\u@\h\[\e[0m\]:\[\e[34m\]\w\[\e[33m\]$(__git_ps1 " (%s)" 2>/dev/null)\[\e[0m\]\$ '
else
  PS1='\[\e[32m\]\u@\h\[\e[0m\]:\[\e[34m\]\w\[\e[0m\]\$ '
fi

# ── fzf ─────────────────────────────────────────────────
[ -f ~/.fzf.bash ] && source ~/.fzf.bash

# ── Claude Code self-repair (slow-egress pods) ───────────
# claude's auto-updater swaps in the small wrapper before the ~238MB native
# binary finishes downloading; a shell opened in that window sees a placeholder
# `claude.exe` (<100MB) and `claude` fails. If a known-good native binary is
# cached on /DATA1, restore it instantly (zero download). This lets auto-update
# stay ON (no version pin) while new terminals never hit the broken window.
# Cheap: a couple of stat calls; only does work when actually broken.
_mts_claude_heal() {
  local w c cache=/DATA1/hongcheol/.cache/claude-native
  for w in /usr/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe \
           /usr/local/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe; do
    [ -f "$w" ] || continue
    [ "$(stat -c%s "$w" 2>/dev/null || echo 0)" -ge 104857600 ] && return 0
    c="$(ls -1v "$cache" 2>/dev/null | tail -1)"
    [ -n "$c" ] || return 0
    cp "$cache/$c" "$w" 2>/dev/null && chmod +x "$w" 2>/dev/null \
      && echo "[mts] restored claude native binary from cache ($c)"
    return 0
  done
}
_mts_claude_heal
unset -f _mts_claude_heal 2>/dev/null

# ── ML / Quantization (shared cache env on /DATA1) ───────
# pip wheels, HF models, nltk data + HF_HUB_ENABLE_HF_TRANSFER. Single source of
# truth shared with the install run (bootstrap.sh sources the same file).
[ -f /DATA1/hongcheol/dotfiles/config/env.sh ] && source /DATA1/hongcheol/dotfiles/config/env.sh
